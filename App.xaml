<Application x:Class="lgv.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="UI/MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="AppForeground" Color="#FFDCDCDC"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3A5A8A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FF3F3F3F"/>
    </Application.Resources>
</Application>
