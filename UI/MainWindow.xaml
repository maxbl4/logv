<Window x:Class="lgv.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LGV — Log Viewer"
        Width="1200" Height="800"
        MinWidth="640" MinHeight="400"
        Background="#FF1E1E1E"
        Foreground="#FFDCDCDC">

    <Window.Resources>
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
        </Style>
        <Style TargetType="ToolBar">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
        </Style>
        <Style TargetType="Button" x:Key="ToolbarButton">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ToggleButton" x:Key="ToolbarToggle">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF3F3F3F"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="BorderBrush" Value="#FF3F3F3F"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="DarkCombo">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl+Shift" Command="{Binding OpenDirectoryCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}"/>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding ToggleAutoScrollCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding ToggleDirWatchCommand}"/>
    </Window.InputBindings>

    <DockPanel LastChildFill="True">

        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top" Background="#FF2D2D2D">
            <MenuItem Header="_File" Background="#FF2D2D2D" Foreground="#FFDCDCDC">
                <MenuItem Header="Open _File..." InputGestureText="Ctrl+O"
                          Click="OpenFileMenu_Click"/>
                <MenuItem Header="Open _Directory..." InputGestureText="Ctrl+Shift+O"
                          Click="OpenDirectoryMenu_Click"/>
                <Separator Background="#FF3F3F3F"/>
                <MenuItem Header="Close Tab" InputGestureText="Ctrl+W"
                          Click="CloseTabMenu_Click"/>
                <Separator Background="#FF3F3F3F"/>
                <MenuItem Header="E_xit" Click="ExitMenu_Click"/>
            </MenuItem>
            <MenuItem Header="_View" Background="#FF2D2D2D" Foreground="#FFDCDCDC">
                <MenuItem Header="Toggle _Highlighting"
                          x:Name="ToggleHighlightingMenuItem"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="ToggleHighlighting_Click"/>
                <MenuItem Header="Toggle _AutoScroll"
                          x:Name="ToggleAutoScrollMenuItem"
                          IsCheckable="True"
                          IsChecked="False"
                          Click="ToggleAutoScroll_Click"/>
                <Separator Background="#FF3F3F3F"/>
                <MenuItem Header="Go To _Line..." InputGestureText="Ctrl+G"
                          Click="GoToLineMenu_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" Background="#FF2D2D2D">
            <ToolBar Background="#FF2D2D2D" Foreground="#FFDCDCDC"
                     Band="0" BandIndex="0">
                <Button Style="{StaticResource ToolbarButton}"
                        Content="📂 Open File" Click="OpenFileMenu_Click"
                        ToolTip="Open File (Ctrl+O)"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Content="📁 Open Dir" Click="OpenDirectoryMenu_Click"
                        ToolTip="Open Directory (Ctrl+Shift+O)"/>

                <Separator Background="#FF3F3F3F"/>

                <ToggleButton x:Name="WatchDirToggle"
                              Style="{StaticResource ToolbarToggle}"
                              Content="Watch Dir: ON"
                              IsChecked="True"
                              Checked="WatchDirToggle_Checked"
                              Unchecked="WatchDirToggle_Unchecked"
                              ToolTip="Toggle directory watch mode (Ctrl+D)"/>

                <ToggleButton x:Name="AutoScrollToggle"
                              Style="{StaticResource ToolbarToggle}"
                              Content="AutoScroll: OFF"
                              IsChecked="False"
                              Checked="AutoScrollToggle_Checked"
                              Unchecked="AutoScrollToggle_Unchecked"
                              ToolTip="Toggle auto-scroll to bottom (Ctrl+T)"/>

                <Separator Background="#FF3F3F3F"/>

                <Label Content="Poll:" Foreground="#FFAAAAAA"/>
                <ComboBox x:Name="PollIntervalCombo"
                          Style="{StaticResource DarkCombo}"
                          Width="80"
                          SelectionChanged="PollIntervalCombo_SelectionChanged">
                    <ComboBoxItem Content="250ms" Tag="250"/>
                    <ComboBoxItem Content="500ms" Tag="500" IsSelected="True"/>
                    <ComboBoxItem Content="1000ms" Tag="1000"/>
                    <ComboBoxItem Content="2000ms" Tag="2000"/>
                </ComboBox>
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#FF2D2D2D">
            <StatusBarItem>
                <TextBlock x:Name="StatusFilePath" Text="No file open"
                           Foreground="#FFAAAAAA" MaxWidth="400"
                           TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>
            <Separator Background="#FF3F3F3F"/>
            <StatusBarItem HorizontalContentAlignment="Center">
                <TextBlock x:Name="StatusLineInfo" Text=""
                           Foreground="#FFAAAAAA"/>
            </StatusBarItem>
            <Separator Background="#FF3F3F3F"/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="StatusTail" Text="Idle"
                           Foreground="#FFAAAAAA"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Tab control -->
        <TabControl x:Name="TabControl"
                    Background="#FF1E1E1E"
                    BorderBrush="#FF3F3F3F"
                    SelectionChanged="TabControl_SelectionChanged">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#FF2D2D2D"/>
                    <Setter Property="Foreground" Value="#FFAAAAAA"/>
                    <Setter Property="BorderBrush" Value="#FF3F3F3F"/>
                    <Setter Property="BorderThickness" Value="1,1,1,0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF1E1E1E"/>
                            <Setter Property="Foreground" Value="#FFDCDCDC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.ItemContainerStyle>
        </TabControl>

    </DockPanel>
</Window>
