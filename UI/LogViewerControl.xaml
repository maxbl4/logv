<UserControl x:Class="lgv.UI.LogViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             Background="#FF1E1E1E"
             Foreground="#FFDCDCDC">

    <UserControl.Resources>
        <Style TargetType="TextBox" x:Key="DarkTextBox">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#FFDCDCDC"/>
        </Style>
        <Style TargetType="Button" x:Key="DarkButton">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ToggleButton" x:Key="DarkToggle">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="DarkCheckBox">
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label" x:Key="DarkLabel">
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Editor + Tick Canvas overlay -->
        <Grid Grid.Row="0">
            <avalonEdit:TextEditor
                x:Name="Editor"
                Background="#FF1E1E1E"
                Foreground="#FFDCDCDC"
                FontFamily="Consolas"
                FontSize="13"
                IsReadOnly="True"
                ShowLineNumbers="True"
                WordWrap="False"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Visible"
                BorderThickness="0"/>

            <!-- Tick canvas overlaid on right side (over scrollbar) -->
            <Canvas x:Name="TickCanvas"
                    Width="17"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="False"
                    Background="Transparent"/>
        </Grid>

        <!-- Row 1: Filter bar (collapsed by default) -->
        <Border Grid.Row="1"
                x:Name="FilterBar"
                Background="#FF2D2D2D"
                BorderBrush="#FF3F3F3F"
                BorderThickness="0,1,0,0"
                Padding="4,3"
                Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <Button x:Name="FilterCloseBtn"
                        DockPanel.Dock="Left"
                        Style="{StaticResource DarkButton}"
                        Content="✕"
                        Width="24"
                        Margin="0,0,4,0"
                        Click="FilterCloseBtn_Click"
                        ToolTip="Close filter (Escape)"/>
                <Label DockPanel.Dock="Left"
                       Style="{StaticResource DarkLabel}"
                       Content="Filter:"/>
                <Button x:Name="FilterClearBtn"
                        DockPanel.Dock="Right"
                        Style="{StaticResource DarkButton}"
                        Content="Clear"
                        Margin="4,0,0,0"
                        Click="FilterClearBtn_Click"/>
                <Label x:Name="FilterStatusLabel"
                       DockPanel.Dock="Right"
                       Style="{StaticResource DarkLabel}"
                       Content=""
                       MinWidth="80"
                       HorizontalContentAlignment="Right"/>
                <CheckBox x:Name="FilterRegexChk"
                          DockPanel.Dock="Right"
                          Style="{StaticResource DarkCheckBox}"
                          Content="Regex"
                          Margin="4,0"
                          Checked="FilterRegexChk_Changed"
                          Unchecked="FilterRegexChk_Changed"/>
                <ToggleButton x:Name="FilterModeBtn"
                              DockPanel.Dock="Right"
                              Style="{StaticResource DarkToggle}"
                              Content="Include"
                              Margin="4,0"
                              Checked="FilterModeBtn_Checked"
                              Unchecked="FilterModeBtn_Unchecked"
                              ToolTip="Toggle Include/Exclude"/>
                <TextBox x:Name="FilterBox"
                         Style="{StaticResource DarkTextBox}"
                         TextChanged="FilterBox_TextChanged"
                         KeyDown="FilterBox_KeyDown"/>
            </DockPanel>
        </Border>

        <!-- Row 2: Search bar (collapsed by default) -->
        <Border Grid.Row="2"
                x:Name="SearchBar"
                Background="#FF2D2D2D"
                BorderBrush="#FF3F3F3F"
                BorderThickness="0,1,0,0"
                Padding="4,3"
                Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <Button x:Name="SearchCloseBtn"
                        DockPanel.Dock="Left"
                        Style="{StaticResource DarkButton}"
                        Content="✕"
                        Width="24"
                        Margin="0,0,4,0"
                        Click="SearchCloseBtn_Click"
                        ToolTip="Close search (Escape)"/>
                <Label DockPanel.Dock="Left"
                       Style="{StaticResource DarkLabel}"
                       Content="Search:"/>
                <Button x:Name="SearchNextBtn"
                        DockPanel.Dock="Right"
                        Style="{StaticResource DarkButton}"
                        Content="▼"
                        Width="28"
                        Margin="2,0,0,0"
                        Click="SearchNextBtn_Click"
                        ToolTip="Next match (F3)"/>
                <Button x:Name="SearchPrevBtn"
                        DockPanel.Dock="Right"
                        Style="{StaticResource DarkButton}"
                        Content="▲"
                        Width="28"
                        Margin="2,0,0,0"
                        Click="SearchPrevBtn_Click"
                        ToolTip="Previous match (Shift+F3)"/>
                <Label x:Name="SearchCountLabel"
                       DockPanel.Dock="Right"
                       Style="{StaticResource DarkLabel}"
                       Content="0 of 0"
                       MinWidth="70"
                       HorizontalContentAlignment="Right"/>
                <CheckBox x:Name="SearchRegexChk"
                          DockPanel.Dock="Right"
                          Style="{StaticResource DarkCheckBox}"
                          Content=".*"
                          Margin="4,0"
                          ToolTip="Use regular expressions"
                          Checked="SearchOptions_Changed"
                          Unchecked="SearchOptions_Changed"/>
                <CheckBox x:Name="SearchCaseChk"
                          DockPanel.Dock="Right"
                          Style="{StaticResource DarkCheckBox}"
                          Content="Aa"
                          Margin="4,0"
                          ToolTip="Match case"
                          Checked="SearchOptions_Changed"
                          Unchecked="SearchOptions_Changed"/>
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource DarkTextBox}"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
