<UserControl x:Class="lgv.UI.LogViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit">

    <UserControl.Resources>
        <Style TargetType="TextBox" x:Key="DarkTextBox">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button" x:Key="DarkButton">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ToggleButton" x:Key="DarkToggle">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="DarkCheckBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label" x:Key="DarkLabel">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="50"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Editor + Tick Canvas overlay -->
        <Grid Grid.Row="0">
            <avalonEdit:TextEditor
                x:Name="Editor"
                FontFamily="Consolas"
                FontSize="13"
                IsReadOnly="True"
                WordWrap="False"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Visible"
                BorderThickness="0"/>

            <!-- Tick canvas overlaid on right side (over scrollbar) -->
            <Canvas x:Name="TickCanvas"
                    AutomationProperties.AutomationId="TickCanvas"
                    Width="17"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="False"
                    Background="Transparent"/>

            <!-- 1×1 pixel buttons for UI-test automation (InvokePattern). x:Name doubles as AutomationId. -->
            <Button x:Name="ShowSearchBarBtn"
                    Width="1" Height="1"
                    IsTabStop="False" Focusable="False"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Click="ShowSearchBarBtn_Click"/>
            <Button x:Name="ScrollToTopBtn"
                    Width="1" Height="1"
                    IsTabStop="False" Focusable="False"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Click="ScrollToTopBtn_Click"/>
            <Button x:Name="ScrollToEndBtn"
                    Width="1" Height="1"
                    IsTabStop="False" Focusable="False"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Click="ScrollToEndBtn_Click"/>
        </Grid>

        <!-- Row 1: Search bar (collapsed by default) -->
        <Border Grid.Row="1"
                x:Name="SearchBar"
                Background="{x:Static SystemColors.ControlBrush}"
                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                BorderThickness="0,1,0,0"
                Padding="4,3"
                Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <Button x:Name="SearchCloseBtn"
                        DockPanel.Dock="Left"
                        Style="{StaticResource DarkButton}"
                        Content="✕"
                        Width="24"
                        Margin="0,0,4,0"
                        Click="SearchCloseBtn_Click"
                        ToolTip="Close search (Escape)"/>
                <Label DockPanel.Dock="Left"
                       Style="{StaticResource DarkLabel}"
                       Content="Search:"/>
                <Button x:Name="SearchNextBtn"
                        DockPanel.Dock="Right"
                        Style="{StaticResource DarkButton}"
                        Content="▼"
                        Width="28"
                        Margin="2,0,0,0"
                        Click="SearchNextBtn_Click"
                        ToolTip="Next match (F3)"/>
                <Button x:Name="SearchPrevBtn"
                        DockPanel.Dock="Right"
                        Style="{StaticResource DarkButton}"
                        Content="▲"
                        Width="28"
                        Margin="2,0,0,0"
                        Click="SearchPrevBtn_Click"
                        ToolTip="Previous match (Shift+F3)"/>
                <Label x:Name="SearchCountLabel"
                       DockPanel.Dock="Right"
                       Style="{StaticResource DarkLabel}"
                       Content="0 of 0"
                       MinWidth="70"
                       HorizontalContentAlignment="Right"/>
                <CheckBox x:Name="SearchRegexChk"
                          DockPanel.Dock="Right"
                          Style="{StaticResource DarkCheckBox}"
                          Content=".*"
                          Margin="4,0"
                          ToolTip="Use regular expressions"
                          Checked="SearchOptions_Changed"
                          Unchecked="SearchOptions_Changed"/>
                <CheckBox x:Name="SearchCaseChk"
                          DockPanel.Dock="Right"
                          Style="{StaticResource DarkCheckBox}"
                          Content="Aa"
                          Margin="4,0"
                          ToolTip="Match case"
                          Checked="SearchOptions_Changed"
                          Unchecked="SearchOptions_Changed"/>
                <TextBox x:Name="SearchBox"
                         AutomationProperties.AutomationId="SearchBox"
                         Style="{StaticResource DarkTextBox}"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"/>
            </DockPanel>
        </Border>
        <!-- Hidden automation element: setting a raw line number here navigates the editor. -->
        <TextBox x:Name="AutoGoToLineBox"
                 AutomationProperties.AutomationId="AutoGoToLineBox"
                 Grid.Row="0"
                 Width="1" Height="1"
                 Opacity="0"
                 IsTabStop="False"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 TextChanged="AutoGoToLineBox_TextChanged"/>
    </Grid>
</UserControl>
