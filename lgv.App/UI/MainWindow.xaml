<Window x:Class="lgv.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LGV — Log Viewer"
        Width="1200" Height="800"
        MinWidth="640" MinHeight="400"
        Background="#FF1E1E1E"
        Foreground="#FFDCDCDC"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
        </Style>
        <Style TargetType="ToolBar">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
        </Style>
        <Style TargetType="Button" x:Key="ToolbarButton">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ToggleButton" x:Key="ToolbarToggle">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF3F3F3F"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="BorderBrush" Value="#FF3F3F3F"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="DarkCombo">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl+Shift" Command="{Binding OpenDirectoryCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}"/>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding ToggleAutoScrollCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding ToggleDirWatchCommand}"/>
    </Window.InputBindings>

    <DockPanel LastChildFill="True">

        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top" Background="#FF2D2D2D">
            <MenuItem Header="_File" Background="#FF2D2D2D" Foreground="#FFDCDCDC">
                <MenuItem Header="Open _File..." InputGestureText="Ctrl+O"
                          Click="OpenFileMenu_Click"/>
                <MenuItem Header="Open _Directory..." InputGestureText="Ctrl+Shift+O"
                          Click="OpenDirectoryMenu_Click"/>
                <Separator Background="#FF3F3F3F"/>
                <MenuItem Header="_Reload File" InputGestureText="F5"
                          Click="ReloadFileMenu_Click"/>
                <Separator Background="#FF3F3F3F"/>
                <MenuItem Header="Close _All Files in All Directories"
                          Click="CloseAllFilesGlobal_Click"/>
                <MenuItem Header="Close All _But Newest in All Directories"
                          Click="CloseAllButNewestGlobal_Click"/>
                <Separator Background="#FF3F3F3F"/>
                <MenuItem Header="Close Tab" InputGestureText="Ctrl+W"
                          Click="CloseTabMenu_Click"/>
                <Separator Background="#FF3F3F3F"/>
                <MenuItem Header="E_xit" Click="ExitMenu_Click"/>
            </MenuItem>
            <MenuItem Header="_View" Background="#FF2D2D2D" Foreground="#FFDCDCDC">
                <MenuItem Header="Toggle _Highlighting"
                          x:Name="ToggleHighlightingMenuItem"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="ToggleHighlighting_Click"/>
                <MenuItem Header="Toggle _AutoScroll" InputGestureText="Ctrl+T"
                          x:Name="ToggleAutoScrollMenuItem"
                          IsCheckable="True"
                          IsChecked="False"
                          Click="ToggleAutoScroll_Click"/>
                <MenuItem Header="Toggle _Directory Watch" InputGestureText="Ctrl+D"
                          x:Name="ToggleDirWatchMenuItem"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="ToggleDirWatchMenu_Click"/>
                <Separator Background="#FF3F3F3F"/>
                <MenuItem Header="Go To _Line..." InputGestureText="Ctrl+G"
                          Click="GoToLineMenu_Click"/>
            </MenuItem>
            <MenuItem Header="_Search" Background="#FF2D2D2D" Foreground="#FFDCDCDC">
                <MenuItem Header="_Find..." InputGestureText="Ctrl+F"
                          Click="FindMenu_Click"/>
                <MenuItem Header="_Filter..." InputGestureText="Ctrl+Shift+F"
                          Click="FilterMenu_Click"/>
                <Separator Background="#FF3F3F3F"/>
                <MenuItem Header="_Next Match" InputGestureText="F3"
                          Click="NextMatchMenu_Click"/>
                <MenuItem Header="_Previous Match" InputGestureText="Shift+F3"
                          Click="PrevMatchMenu_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" Background="#FF2D2D2D">
            <ToolBar Background="#FF2D2D2D" Foreground="#FFDCDCDC"
                     Band="0" BandIndex="0">
                <Button Style="{StaticResource ToolbarButton}"
                        Content="📂 Open File" Click="OpenFileMenu_Click"
                        ToolTip="Open File (Ctrl+O)"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Content="📁 Open Dir" Click="OpenDirectoryMenu_Click"
                        ToolTip="Open Directory (Ctrl+Shift+O)"/>

                <Separator Background="#FF3F3F3F"/>

                <ToggleButton x:Name="WatchDirToggle"
                              Style="{StaticResource ToolbarToggle}"
                              Content="Watch Dir: ON"
                              IsChecked="True"
                              Checked="WatchDirToggle_Checked"
                              Unchecked="WatchDirToggle_Unchecked"
                              ToolTip="Toggle directory watch mode (Ctrl+D)"/>

                <ToggleButton x:Name="AutoScrollToggle"
                              Style="{StaticResource ToolbarToggle}"
                              Content="AutoScroll: OFF"
                              IsChecked="False"
                              Checked="AutoScrollToggle_Checked"
                              Unchecked="AutoScrollToggle_Unchecked"
                              ToolTip="Toggle auto-scroll to bottom (Ctrl+T)"/>

                <Separator Background="#FF3F3F3F"/>

                <Label Content="Poll:" Foreground="#FFAAAAAA"/>
                <ComboBox x:Name="PollIntervalCombo"
                          Style="{StaticResource DarkCombo}"
                          Width="80"
                          SelectionChanged="PollIntervalCombo_SelectionChanged">
                    <ComboBoxItem Content="250ms" Tag="250"/>
                    <ComboBoxItem Content="500ms" Tag="500" IsSelected="True"/>
                    <ComboBoxItem Content="1000ms" Tag="1000"/>
                    <ComboBoxItem Content="2000ms" Tag="2000"/>
                </ComboBox>
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#FF2D2D2D">
            <StatusBarItem>
                <TextBlock x:Name="StatusFilePath" Text="No file open"
                           Foreground="#FFAAAAAA" MaxWidth="400"
                           TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>
            <Separator Background="#FF3F3F3F"/>
            <StatusBarItem HorizontalContentAlignment="Center">
                <TextBlock x:Name="StatusLineInfo" Text=""
                           Foreground="#FFAAAAAA"/>
            </StatusBarItem>
            <Separator Background="#FF3F3F3F"/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="StatusTail" Text="Idle"
                           Foreground="#FFAAAAAA"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Tab + global filter panel -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="GlobalFilterSplitterRow" Height="0"/>
                <RowDefinition x:Name="GlobalFilterPanelRow" Height="0" MinHeight="0"/>
            </Grid.RowDefinitions>

            <!-- Tab control (level 1: direct files and directory containers) -->
            <TabControl x:Name="TabControl"
                        Grid.Row="0"
                        Background="#FF1E1E1E"
                        BorderBrush="#FF3F3F3F"
                        ItemContainerStyle="{StaticResource DarkTabItemStyle}"
                        SelectionChanged="TabControl_SelectionChanged"/>

            <!-- Global filter splitter -->
            <GridSplitter x:Name="GlobalFilterSplitter"
                          Grid.Row="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          Background="#FF555555"
                          Cursor="SizeNS"
                          Visibility="Collapsed"/>

            <!-- Global filter panel -->
            <Border x:Name="GlobalFilterPanel"
                    Grid.Row="2"
                    Background="#FF252526"
                    BorderBrush="#FF3F3F3F"
                    BorderThickness="0,1,0,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Background="#FF2D2D2D"
                               LastChildFill="False"
                               Margin="0,0,0,1">
                        <Button x:Name="GlobalFilterCloseBtn"
                                DockPanel.Dock="Left"
                                Style="{StaticResource ToolbarButton}"
                                Content="✕"
                                Width="24"
                                Margin="4,3,0,3"
                                Click="GlobalFilterCloseBtn_Click"
                                ToolTip="Close filter (Escape)"/>
                        <Label DockPanel.Dock="Left"
                               Content="Filter Patterns"
                               FontWeight="SemiBold"
                               Margin="4,0"/>
                        <Label DockPanel.Dock="Left"
                               Content="(one regex per line — excludes matching lines, # = comment)"
                               Foreground="#FF777777"
                               FontSize="11"/>
                        <Button x:Name="GlobalFilterClearBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource ToolbarButton}"
                                Content="Clear"
                                Margin="4,3"
                                Click="GlobalFilterClearBtn_Click"/>
                        <Label x:Name="GlobalFilterStatusLabel"
                               DockPanel.Dock="Right"
                               MinWidth="140"
                               HorizontalContentAlignment="Right"/>
                    </DockPanel>

                    <TextBox x:Name="GlobalFilterBox"
                             Grid.Row="1"
                             Background="#FF3C3C3C"
                             Foreground="#FFDCDCDC"
                             BorderBrush="#FF555555"
                             CaretBrush="#FFDCDCDC"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalContentAlignment="Top"
                             Padding="6,4"
                             BorderThickness="0"
                             TextChanged="GlobalFilterBox_TextChanged"
                             KeyDown="GlobalFilterBox_KeyDown"/>
                </Grid>
            </Border>
        </Grid>

    </DockPanel>
</Window>
